# Local development uses SQLite (a file) — no database server needed.
DATABASE_URI=file:./data/portfolio.db
PAYLOAD_SECRET=your-secret-here-generate-with-openssl-rand-hex-32

# Media uploads directory. In production this is the mounted Azure Files volume.
# MEDIA_DIR=./media

# Transactional email (contact form) — Azure Communication Services.
AZURE_COMMUNICATION_CONNECTION_STRING=
EMAIL_FROM=DoNotReply@example.com
CONTACT_EMAIL_TO=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Application Insights (free tier) telemetry in production.
APPLICATIONINSIGHTS_CONNECTION_STRING=
